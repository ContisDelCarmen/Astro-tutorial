---

import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const {
pageTitle,
skillColor = "crimson",
fontWeight = "bold",
textCase = "uppercase",
} = Astro.props;
---


<html lang="en">

<head>
  <meta charset="utf-8" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" href="/favicon.ico" />
  <meta name="viewport" content="width=device-width" />
  <meta name="generator" content={Astro.generator} />
  <title>{pageTitle}</title>

  <style>
    /* estilos globales para que afecten al contenido de las páginas */
    :global(h1) {
      color: purple;
      font-size: 2rem;
      margin: 0 0 1rem 0;
    }

    /* valores por defecto; pueden sobrescribirse por página vía props */
    :root {
      --skill-color: crimson;
      --skill-weight: bold;
      --skill-case: uppercase;
    }

    :global(.skill) {
      color: var(--skill-color);
      font-weight: var(--skill-weight);
      text-transform: var(--skill-case);
    }
  </style>
</head>

<body style={`--skill-color:${skillColor}; --skill-weight:${fontWeight};
  --skill-case:${String(textCase).toLowerCase()}`}>
  <Header />
  <h1>{pageTitle}</h1>

  <slot />

  <Footer />
  <script type="module">
    import '/src/scripts/menu.js';
  </script>

</body>

</html>